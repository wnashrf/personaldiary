# Personal Diary API Tests
# Base URL
@baseUrl = http://localhost:5000/api

# Variables (update these after running requests)
@token = <JWT_TOKEN>
@userId = <USER_ID>
@diaryId = <DIARY_ENTRY_ID>

### Register User
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "test123",
  "email": "test123@example.com",
  "password": "password123"
}

### Login User
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "test123@example.com",
  "password": "password123"
}

### Create Diary Entry (requires token from login)
POST {{baseUrl}}/diaries
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "title": "My First Diary Entry",
  "content": "This is my first diary entry. I'm excited to start journaling!",
  "mood": "happy"
}

### Get All Diary Entries
GET {{baseUrl}}/diaries
Authorization: Bearer {{token}}

### Get Diary Entry by ID
GET {{baseUrl}}/diaries/{{diaryId}}
Authorization: Bearer {{token}}

### Update Diary Entry
PUT {{baseUrl}}/diaries/{{diaryId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "title": "Updated Diary Entry",
  "content": "I've updated this diary entry with new thoughts.",
  "mood": "reflective"
}

### Delete Diary Entry
DELETE {{baseUrl}}/diaries/{{diaryId}}
Authorization: Bearer {{token}}